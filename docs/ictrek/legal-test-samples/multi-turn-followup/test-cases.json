          "expected_carryover_terms": ["迟延交付", "设备", "20 天"],
          "expected_new_points": ["继续履行", "违约金", "赔偿损失"],
          "citation_terms": ["民法典", "违约责任", "继续履行", "赔偿损失"],
          "forbidden_patterns": ["只能解除", "不能主张赔偿"]
        },
        {
          "turn": 2,
          "query": "合同约定逾期违约金每天 100 元，但买方停产损失明显更高，能否要求提高或另行赔偿？",
          "expected_carryover_terms": ["迟延交付", "逾期违约金", "停产损失"],
          "expected_new_points": ["违约金过低", "请求增加", "实际损失"],
          "citation_terms": ["民法典", "违约金", "过低", "损失"],
          "forbidden_patterns": ["违约金约定后.*不能调整", "只能按每天 100 元"]
        },
        {
          "turn": 3,
          "query": "合同没有写清验收标准，供应商说已经交货，买方说不能验收，这会影响迟延交付责任吗？",
          "expected_carryover_terms": ["迟延交付", "违约金", "验收标准"],
          "expected_new_points": ["验收标准不清", "合格交付", "举证"],
          "citation_terms": ["民法典", "买卖合同", "验收", "检验"],
          "forbidden_patterns": ["没有验收标准.*一定不能追责", "供应商说交货.*当然免责"]
        },
        {
          "turn": 4,
          "query": "买方已经发过两次书面催告并保留邮件记录，这对解除合同或主张损失有什么帮助？",
          "expected_carryover_terms": ["迟延交付", "验收", "书面催告"],
          "expected_new_points": ["催告", "解除合同", "证据"],
          "citation_terms": ["民法典", "催告", "解除", "损失"],
          "forbidden_patterns": ["发催告.*一定解除成功", "无需证明损失"]
        }
      ],
      "expected_final_sections": ["结论", "依据", "风险", "证据建议"],
      "pass_criteria": "多数轮次能承接迟延交付主线，并围绕违约金调整、验收争议、催告证据给出递进判断和依据。"
    },

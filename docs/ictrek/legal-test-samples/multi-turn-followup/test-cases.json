{
  "version": 1,
  "tests": [
    {
      "id": "MTF-001",
      "title": "劳动合同解除多轮追问",
      "priority": "P0",
      "scenario": "劳动合同解除：首轮问违法解除风险，追问补充试用期、严重违纪、未签书面劳动合同等事实。",
      "knowledge_base_ids": ["law"],
      "turns": [
        {
          "turn": 1,
          "query": "公司想解除一名入职 5 个月员工的劳动合同，目前只知道绩效不达标，没有书面考核记录。违法解除风险大吗？",
          "expected_carryover_terms": ["入职 5 个月", "绩效不达标", "书面考核"],
          "expected_new_points": ["违法解除风险", "证据不足", "考核记录"],
          "citation_terms": ["劳动合同法", "违法解除", "赔偿金", "经济补偿"],
          "forbidden_patterns": ["一定合法", "没有风险", "可以直接解除"]
        },
        {
          "turn": 2,
          "query": "补充一下，这名员工还在试用期内，公司能否因为“不符合录用条件”直接解除？",
          "expected_carryover_terms": ["解除劳动合同", "绩效不达标", "试用期"],
          "expected_new_points": ["不符合录用条件", "证明", "不能直接解除"],
          "citation_terms": ["劳动合同法", "试用期", "录用条件"],
          "forbidden_patterns": ["试用期.*任意解除", "试用期.*随时解除", "直接解除.*无需证明"]
        },
        {
          "turn": 3,
          "query": "如果后来发现他多次伪造报销单，公司规章制度中明确列为严重违纪，结论会变化吗？",
          "expected_carryover_terms": ["试用期", "解除", "伪造报销"],
          "expected_new_points": ["严重违纪", "规章制度", "风险下降"],
          "citation_terms": ["劳动合同法", "严重违反", "规章制度"],
          "forbidden_patterns": ["仍然一定违法", "严重违纪.*没有影响"]
        },
        {
          "turn": 4,
          "query": "再补充一个事实：公司一直没有和他签书面劳动合同，这会影响解除风险和赔偿责任吗？",
          "expected_carryover_terms": ["严重违纪", "解除", "未签书面劳动合同"],
          "expected_new_points": ["双倍工资", "独立违法行为", "不当然影响解除"],
          "citation_terms": ["劳动合同法", "书面劳动合同", "二倍工资", "双倍工资"],
          "forbidden_patterns": ["没有签合同.*不存在劳动关系", "未签合同.*不能解除", "未签合同.*无需赔偿"]
        }
      ],
      "expected_final_sections": ["结论", "依据", "风险", "建议"],
      "pass_criteria": "多数轮次同时命中承接事实、增量判断和劳动合同法依据，且没有把试用期、严重违纪或未签合同作绝对化处理。"
    },
    {
      "id": "MTF-002",
      "title": "消费者退货退款多轮追问",
      "priority": "P0",
      "scenario": "消费者权益保护：首轮问退货退款，追问补充网购、线下购买、定制商品、超过七日等事实。",
      "knowledge_base_ids": ["law"],
      "turns": [
        {
          "turn": 1,

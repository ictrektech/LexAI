    {
      "id": "MTF-005",
      "title": "消费者案例争点多轮追问",
      "priority": "P1",
      "scenario": "案例追问：首轮要求提炼案例争点，后续追问要求说明裁判理由并比较相似案例。",
      "knowledge_base_ids": ["case", "law"],
      "turns": [
        {
          "turn": 1,
          "query": "请从法律案例库中选择一个消费者权益保护相关案例，提炼案件事实、争议焦点和裁判结果。",
          "expected_carryover_terms": ["消费者", "案例", "争议焦点"],
          "expected_new_points": ["案件事实", "裁判结果", "法院"],
          "citation_terms": ["案例", "法院", "判决", "裁判"],
          "forbidden_patterns": ["虚构案例", "随便举例"]
        },
        {
          "turn": 2,
          "query": "承接刚才这个案例，请说明法院支持或不支持消费者主张的核心裁判理由。",
          "expected_carryover_terms": ["刚才这个案例", "消费者主张", "法院"],
          "expected_new_points": ["裁判理由", "事实认定", "法律适用"],
          "citation_terms": ["法院认为", "本院认为", "裁判理由", "消费者权益保护法"],
          "forbidden_patterns": ["换一个案例", "无法知道刚才案例"]
        },
        {
          "turn": 3,

          "expected_carryover_terms": ["刚才", "案例", "裁判理由"],
          "expected_new_points": ["相似案例", "事实要素", "差异"],
          "citation_terms": ["案例", "相似", "裁判", "未检索到"],
          "forbidden_patterns": ["编造", "\\（20\\d{2}\\）[^\\s，。；；、]{3,}999999"]
        }
      ],
      "expected_final_sections": ["案例", "争议焦点", "裁判理由", "差异"],
      "pass_criteria": "至少 2 轮围绕同一案例继续追问并给出案例依据；如无相似案例，应明确说明而不是编造案号或裁判规则。"

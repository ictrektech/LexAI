          "expected_carryover_terms": ["商品", "退货退款"],
          "expected_new_points": ["质量问题", "无理由退货", "经营者承诺"],
          "citation_terms": ["消费者权益保护法", "退货", "退款"],
          "forbidden_patterns": ["所有商品.*必须退", "不满意.*一定可以退"]
        },
        {
          "turn": 2,
          "query": "如果这是电商平台网购，消费者收到货第 3 天提出退货，是否适用七日无理由退货？",
          "expected_carryover_terms": ["退货退款", "网购", "第 3 天"],
          "expected_new_points": ["七日无理由退货", "收到商品", "例外"],
          "citation_terms": ["消费者权益保护法", "七日", "无理由退货"],
          "forbidden_patterns": ["超过七日", "线下购买"]
        },
        {
          "turn": 3,
          "query": "如果同样是第 3 天，但商品是按消费者尺寸定制的西装，还能无理由退货吗？",
          "expected_carryover_terms": ["第 3 天", "网购", "无理由退货"],
          "expected_new_points": ["定制", "定作", "退货例外"],
          "citation_terms": ["消费者权益保护法", "定作", "无理由退货"],
          "forbidden_patterns": ["定制.*一定可以无理由退", "所有网购.*都能退"]
        },
        {
          "turn": 4,
          "query": "如果不是网购，而是线下门店购买，并且已经超过 7 天，还能要求退货退款吗？",
          "expected_carryover_terms": ["退货退款", "线下门店", "超过 7 天"],
          "expected_new_points": ["不当然适用七日无理由", "质量问题", "商家承诺"],
          "citation_terms": ["消费者权益保护法", "七日", "质量"],
          "forbidden_patterns": ["线下.*当然适用七日无理由", "超过.*仍然一定无理由退"]
        }
      ],
      "expected_final_sections": ["结论", "依据", "例外", "建议"],
      "pass_criteria": "多数轮次能沿着退货退款主线，按网购、定制、线下和超过七日事实变化调整结论，并继续引用消费者权益保护法依据。"
    },
    {
      "id": "MTF-003",
      "title": "买卖合同违约责任多轮追问",
      "priority": "P0",
      "scenario": "买卖合同违约责任：首轮问延期交付责任，追问补充违约金过低、未约定验收标准、已有催告记录等事实。",
      "knowledge_base_ids": ["law", "case"],
